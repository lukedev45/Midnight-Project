ble to type '(tx: UnboundTransaction, ttl?: Date | undefined) => Promise<FinalizedTransaction>'.","category":1,"code":2322,"next":[{"messageText":"Target signature provides too few arguments. Expected 3 or more, but got 2.","category":1,"code":2849}]},"relatedInformation":[{"file":"../node_modules/.pnpm/@midnight-ntwrk+midnight-js-types@4.0.4/node_modules/@midnight-ntwrk/midnight-js-types/dist/index.d.mts","start":35239,"length":77,"messageText":"The expected type comes from property 'balanceTx' which is declared here on type 'WalletProvider'","category":3,"code":6500}]},{"start":2776,"length":2,"messageText":"Parameter 'tx' implicitly has an 'any' type.","category":1,"code":7006},{"start":2780,"length":8,"messageText":"Parameter 'newCoins' implicitly has an 'any' type.","category":1,"code":7006},{"start":2790,"length":3,"messageText":"Parameter 'ttl' implicitly has an 'any' type.","category":1,"code":7006},{"start":2872,"length":8,"code":2353,"category":1,"messageText":"Object literal may only specify known properties, and 'newCoins' does not exist in type '{ payFees?: boolean | undefined; }'."},{"start":3053,"length":2,"code":2345,"category":1,"messageText":"Argument of type 'FinalizedTransaction' is not assignable to parameter of type 'string'."},{"start":3074,"length":4,"code":2339,"category":1,"messageText":"Property 'txId' does not exist on type 'FinalizedTransaction'."},{"start":3317,"length":14,"code":2769,"category":1,"messageText":{"messageText":"No overload matches this call.","category":1,"code":2769,"next":[{"messageText":"Overload 1 of 2, '(providers: ContractProviders<Contract<undefined, Witnesses<undefined>>, string, unknown>, options: DeployContractOptionsBase<Contract<undefined, Witnesses<undefined>>>): Promise<...>', gave the following error.","category":1,"code":2772,"next":[{"messageText":"Object literal may only specify known properties, and 'privateStateId' does not exist in type 'DeployContractOptionsBase<Contract<undefined, Witnesses<undefined>>>'.","category":1,"code":2353}]},{"messageText":"Overload 2 of 2, '(providers: ContractProviders<Any, string, any>, options: DeployContractOptionsWithPrivateState<Any>): Promise<...>', gave the following error.","category":1,"code":2772,"next":[{"messageText":"Argument of type '{ compiledContract: never; privateStateId: \"counterState\"; initialPrivateState: {}; }' is not assignable to parameter of type 'DeployContractOptionsWithPrivateState<Any>'.","category":1,"code":2345,"next":[{"messageText":"Property 'args' is missing in type '{ compiledContract: never; privateStateId: \"counterState\"; initialPrivateState: {}; }' but required in type '{ readonly args: any[]; }'.","category":1,"code":2741,"canonicalHead":{"code":2322,"messageText":"Type '{ compiledContract: never; privateStateId: \"counterState\"; initialPrivateState: {}; }' is not assignable to type '{ readonly args: any[]; }'."}}]}]}]},"relatedInformation":[{"file":"../node_modules/.pnpm/@midnight-ntwrk+midnight-js-contracts@4.0.4/node_modules/@midnight-ntwrk/midnight-js-contracts/dist/index.d.mts","start":6266,"length":4,"messageText":"'args' is declared here.","category":3,"code":2728}]}]]],"latestChangedDtsFile":"./dist/index.d.ts","version":"5.9.3"}